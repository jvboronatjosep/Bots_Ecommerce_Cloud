<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>BOT CONTROL — SendingBay</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=IBM+Plex+Mono:wght@300;400;500;600&family=Syne:wght@400;600;700;800&display=swap" rel="stylesheet">
  <script src="https://cdn.jsdelivr.net/npm/ansi_up@5/ansi_up.js"></script>
  <style>
    :root {
      --bg: #ffffff;
      --surface: #ffffff;
      --surface2: #f4fbf6;
      --border: #2db52d;
      --border-bright: #1a8a1a;
      --text: #111111;
      --text-dim: #333333;
      --text-muted: #888888;
      --accent: #1a8a1a;
      --accent-dim: rgba(26, 138, 26, 0.08);
      --accent-glow: rgba(26, 138, 26, 0.20);
      --accent-bright: #2db52d;
      --accent-dark: #0d5200;
      --green-mid: #1a8a1a;
      --red: #cc2233;
      --red-dim: rgba(204, 34, 51, 0.08);
      --yellow: #c07800;
      --yellow-dim: rgba(192, 120, 0, 0.08);
      --mono: 'IBM Plex Mono', monospace;
      --sans: 'Syne', sans-serif;
    }

    * { box-sizing: border-box; margin: 0; padding: 0; }

    body {
      background: var(--bg);
      color: var(--text);
      font-family: var(--sans);
      min-height: 100vh;
      overflow-x: hidden;
    }

    body::before {
      content: '';
      position: fixed;
      inset: 0;
      background-image:
        linear-gradient(rgba(26,138,26,0.05) 1px, transparent 1px),
        linear-gradient(90deg, rgba(26,138,26,0.05) 1px, transparent 1px);
      background-size: 40px 40px;
      pointer-events: none;
      z-index: 0;
    }

    .layout {
      position: relative;
      z-index: 1;
      display: grid;
      grid-template-columns: 280px 1fr;
      grid-template-rows: 64px 1fr;
      min-height: 100vh;
    }

    /* HEADER */
    header {
      grid-column: 1 / -1;
      display: flex;
      align-items: center;
      padding: 0 24px;
      border-bottom: 1px solid var(--border);
      background: rgba(255,255,255,0.98);
      backdrop-filter: blur(12px);
      position: sticky;
      top: 0;
      z-index: 100;
      gap: 18px;
    }

    .header-logo {
      display: flex;
      align-items: center;
      gap: 10px;
      text-decoration: none;
    }

    .logo-img {
      height: 30px;
      width: auto;
      /* The logo has a black background, we invert it for dark bg or just use as-is */
      filter: brightness(1.1);
    }

    .header-divider {
      width: 1px;
      height: 26px;
      background: var(--border-bright);
      flex-shrink: 0;
    }

    .header-title {
      font-family: var(--mono);
      font-size: 11px;
      font-weight: 500;
      letter-spacing: 3px;
      color: var(--text-dim);
      text-transform: uppercase;
    }

    .header-sep { flex: 1; }

    .header-status {
      display: flex;
      align-items: center;
      gap: 10px;
    }

    .status-pill {
      display: flex;
      align-items: center;
      gap: 6px;
      padding: 5px 12px;
      border: 1px solid var(--border);
      border-radius: 3px;
      font-family: var(--mono);
      font-size: 10px;
      letter-spacing: 1.5px;
      background: var(--surface);
      color: var(--text-dim);
    }

    .status-dot {
      width: 5px; height: 5px;
      border-radius: 50%;
      background: var(--accent);
      box-shadow: 0 0 6px var(--accent-glow);
      animation: pulse 2s ease-in-out infinite;
    }

    @keyframes pulse {
      0%, 100% { opacity: 1; transform: scale(1); }
      50% { opacity: 0.4; transform: scale(0.7); }
    }

    /* SIDEBAR */
    .sidebar {
      border-right: 1px solid var(--border);
      padding: 16px;
      overflow-y: auto;
      display: flex;
      flex-direction: column;
      gap: 6px;
      background: rgba(248,253,249,0.9);
    }

    .sidebar-label {
      font-family: var(--mono);
      font-size: 9px;
      letter-spacing: 3px;
      color: var(--text-muted);
      text-transform: uppercase;
      padding: 10px 4px 6px;
    }

    .run-item {
      padding: 10px 12px;
      border: 1px solid var(--border);
      border-radius: 5px;
      cursor: pointer;
      font-family: var(--mono);
      font-size: 11px;
      transition: all 0.12s;
      display: flex;
      align-items: center;
      gap: 10px;
      background: var(--surface);
    }

    .run-item:hover { border-color: var(--border-bright); background: var(--surface2); }
    .run-item.active { border-color: var(--accent); background: var(--accent-dim); }

    .run-status-dot {
      width: 6px; height: 6px;
      border-radius: 50%;
      flex-shrink: 0;
    }

    .dot-running { background: var(--accent); box-shadow: 0 0 6px var(--accent-glow); animation: pulse 1s infinite; }
    .dot-completed { background: #44cc88; }
    .dot-failed { background: var(--red); }
    .dot-stopped { background: var(--yellow); }

    .run-item-info { flex: 1; min-width: 0; }
    .run-item-name { font-weight: 500; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; color: var(--text); }
    .run-item-meta { color: var(--text-muted); font-size: 10px; margin-top: 2px; }

    /* MAIN */
    .main { display: flex; flex-direction: column; overflow: hidden; }

    .panel {
      flex: 1;
      display: flex;
      flex-direction: column;
      padding: 24px;
      gap: 20px;
      overflow-y: auto;
    }

    .section-title {
      font-family: var(--mono);
      font-size: 9px;
      letter-spacing: 3px;
      color: var(--text-muted);
      text-transform: uppercase;
      display: flex;
      align-items: center;
      gap: 12px;
    }
    .section-title::after {
      content: '';
      flex: 1;
      height: 1px;
      background: var(--border);
    }

    /* Bot selector */
    .bot-selector-grid {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: 10px;
    }

    .bot-select-card {
      border: 1px solid var(--border);
      border-radius: 6px;
      padding: 16px 12px;
      cursor: pointer;
      transition: all 0.15s ease;
      background: var(--surface);
      text-align: center;
      position: relative;
      overflow: hidden;
    }

    .bot-select-card::before {
      content: '';
      position: absolute;
      bottom: 0; left: 0; right: 0;
      height: 2px;
      background: var(--card-color, var(--accent));
      opacity: 0;
      transition: opacity 0.15s;
    }

    .bot-select-card:hover { border-color: var(--border-bright); background: var(--surface2); }
    .bot-select-card:hover::before { opacity: 0.5; }
    .bot-select-card.selected { border-color: var(--card-color, var(--accent)); background: var(--surface2); }
    .bot-select-card.selected::before { opacity: 1; }
    .bot-select-card.unavailable { opacity: 0.3; cursor: not-allowed; }

    .bot-select-icon { font-size: 26px; margin-bottom: 8px; }
    .bot-select-name { font-size: 12px; font-weight: 600; color: var(--text); letter-spacing: 0.3px; }

    .bot-select-check {
      position: absolute;
      top: 8px; right: 8px;
      width: 16px; height: 16px;
      border-radius: 50%;
      border: 1px solid var(--border);
      display: flex; align-items: center; justify-content: center;
      font-size: 9px;
      color: transparent;
      transition: all 0.15s;
    }
    .bot-select-card.selected .bot-select-check {
      background: var(--card-color, var(--accent));
      border-color: var(--card-color, var(--accent));
      color: #ffffff;
    }

    /* Config */
    .config-grid {
      display: grid;
      grid-template-columns: 1fr 1fr 1fr;
      gap: 14px;
    }

    .field-group { display: flex; flex-direction: column; gap: 6px; }

    .field-label {
      font-family: var(--mono);
      font-size: 9px;
      letter-spacing: 2px;
      color: var(--text-muted);
      text-transform: uppercase;
    }

    .field-input {
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: 4px;
      padding: 10px 12px;
      color: var(--text);
      font-family: var(--mono);
      font-size: 14px;
      transition: border-color 0.15s, box-shadow 0.15s;
      width: 100%;
    }
    .field-input:focus {
      outline: none;
      border-color: var(--accent);
      box-shadow: 0 0 0 2px var(--accent-dim);
    }

    .toggle-row {
      display: flex;
      align-items: center;
      gap: 10px;
      padding: 10px 12px;
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: 4px;
      height: 42px;
    }
    .toggle-label { font-family: var(--mono); font-size: 12px; color: var(--text-dim); flex: 1; }
    .toggle { position: relative; width: 36px; height: 20px; cursor: pointer; }
    .toggle input { opacity: 0; width: 0; height: 0; }
    .toggle-track { position: absolute; inset: 0; background: var(--border); border-radius: 10px; transition: background 0.2s; }
    .toggle-thumb { position: absolute; width: 14px; height: 14px; background: var(--text-muted); border-radius: 50%; top: 3px; left: 3px; transition: all 0.2s; }
    .toggle input:checked + .toggle-track { background: var(--accent); }
    .toggle input:checked ~ .toggle-thumb { left: 19px; background: var(--bg); }

    /* Launch button */
    .launch-btn {
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 10px;
      padding: 14px 28px;
      background: linear-gradient(135deg, var(--green-mid), var(--accent));
      color: #ffffff;
      border: none;
      border-radius: 5px;
      font-family: var(--mono);
      font-size: 12px;
      font-weight: 600;
      letter-spacing: 3px;
      text-transform: uppercase;
      cursor: pointer;
      transition: all 0.15s ease;
      width: 100%;
      position: relative;
      overflow: hidden;
    }
    .launch-btn::before {
      content: '';
      position: absolute;
      inset: 0;
      background: linear-gradient(135deg, var(--accent), var(--accent-bright));
      opacity: 0;
      transition: opacity 0.15s;
    }
    .launch-btn:hover::before { opacity: 1; }
    .launch-btn:hover { box-shadow: 0 4px 24px var(--accent-glow); transform: translateY(-1px); }
    .launch-btn span { position: relative; z-index: 1; }
    .launch-btn:disabled {
      background: var(--surface);
      color: var(--text-muted);
      cursor: not-allowed;
      transform: none;
      box-shadow: none;
      border: 1px solid var(--border);
    }
    .launch-btn:disabled::before { display: none; }

    /* Terminal */
    .terminal {
      flex: 1;
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: 6px;
      display: flex;
      flex-direction: column;
      overflow: hidden;
      min-height: 280px;
    }

    .terminal-header {
      display: flex;
      align-items: center;
      padding: 10px 14px;
      border-bottom: 1px solid var(--border);
      gap: 12px;
      background: var(--surface2);
    }
    .terminal-dots { display: flex; gap: 6px; }
    .terminal-dot { width: 10px; height: 10px; border-radius: 50%; }
    .terminal-title { font-family: var(--mono); font-size: 11px; color: var(--text-dim); flex: 1; }
    .terminal-actions { display: flex; gap: 8px; }

    .term-btn {
      padding: 4px 10px;
      border: 1px solid var(--border);
      border-radius: 3px;
      background: transparent;
      color: var(--text-dim);
      font-family: var(--mono);
      font-size: 10px;
      cursor: pointer;
      transition: all 0.1s;
      letter-spacing: 1px;
    }
    .term-btn:hover { border-color: var(--border-bright); color: var(--text); }
    .term-btn.stop { color: var(--red); border-color: rgba(255,68,102,0.3); }
    .term-btn.stop:hover { background: var(--red-dim); border-color: var(--red); }

    .terminal-body {
      flex: 1;
      overflow-y: auto;
      padding: 14px 16px;
      font-family: var(--mono);
      font-size: 12px;
      line-height: 1.8;
      background: #f8fdf9;
    }
    .terminal-body::-webkit-scrollbar { width: 3px; }
    .terminal-body::-webkit-scrollbar-thumb { background: var(--border-bright); border-radius: 2px; }

    .log-line { display: flex; gap: 12px; }
    .log-time { color: var(--text-muted); flex-shrink: 0; }
    .log-text { color: #1a1a1a; word-break: break-all; }
    .log-text.system { color: var(--accent); }
    .log-text.error { color: var(--red); }
    .log-text.warn { color: var(--yellow); }

    .terminal-empty {
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      height: 100%;
      color: var(--text-muted);
      font-family: var(--mono);
      font-size: 12px;
      gap: 8px;
    }
    .terminal-empty-icon { font-size: 28px; opacity: 0.2; }

    /* Run info bar */
    .run-info-bar {
      display: flex;
      align-items: center;
      gap: 16px;
      padding: 10px 16px;
      border: 1px solid var(--border);
      border-radius: 5px;
      background: var(--surface);
      font-family: var(--mono);
      font-size: 11px;
      flex-wrap: wrap;
    }
    .run-info-field { display: flex; gap: 6px; align-items: center; }
    .run-info-key { color: var(--text-muted); }
    .run-info-val { color: var(--text); }

    .status-badge {
      padding: 3px 8px;
      border-radius: 3px;
      font-size: 10px;
      font-weight: 600;
      letter-spacing: 1.5px;
    }
    .status-running { background: var(--accent-dim); color: var(--accent); border: 1px solid rgba(61,220,132,0.3); }
    .status-completed { background: rgba(68,204,136,0.1); color: #44cc88; border: 1px solid rgba(68,204,136,0.3); }
    .status-failed { background: var(--red-dim); color: var(--red); border: 1px solid rgba(255,68,102,0.3); }
    .status-stopped { background: var(--yellow-dim); color: var(--yellow); border: 1px solid rgba(241,196,15,0.3); }

    .empty-state {
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      flex: 1;
      gap: 12px;
      color: var(--text-muted);
      font-family: var(--mono);
      padding: 40px;
    }
    .empty-state-icon { font-size: 40px; opacity: 0.12; }
    .empty-state-title { font-size: 12px; letter-spacing: 3px; }
    .empty-state-sub { font-size: 11px; opacity: 0.5; }

    .extra-params-grid {
      display: grid;
      grid-template-columns: 1fr 1fr 1fr;
      gap: 12px;
    }

    .toast-container { position: fixed; bottom: 24px; right: 24px; z-index: 1000; display: flex; flex-direction: column; gap: 8px; }
    .toast { padding: 12px 16px; border-radius: 5px; font-family: var(--mono); font-size: 12px; border: 1px solid; animation: toast-in 0.2s ease; max-width: 320px; }
    .toast-success { background: var(--accent-dim); border-color: rgba(61,220,132,0.4); color: var(--accent); }
    .toast-error { background: var(--red-dim); border-color: var(--red); color: var(--red); }
    .toast-info { background: var(--surface2); border-color: var(--border-bright); color: var(--text); }
    @keyframes toast-in { from { transform: translateX(20px); opacity: 0; } to { transform: translateX(0); opacity: 1; } }

    ::-webkit-scrollbar { width: 4px; height: 4px; }
    ::-webkit-scrollbar-track { background: transparent; }
    ::-webkit-scrollbar-thumb { background: var(--border); border-radius: 2px; }

    @media (max-width: 900px) {
      .layout { grid-template-columns: 1fr; grid-template-rows: 64px auto 1fr; }
      .sidebar { border-right: none; border-bottom: 1px solid var(--border); max-height: 260px; }
      .bot-selector-grid { grid-template-columns: repeat(2, 1fr); }
      .config-grid { grid-template-columns: 1fr 1fr; }
    }

    /* ── Dark mode ─────────────────────────────────────────────────────────── */
    html[data-theme="dark"] {
      --bg: #0a0a0c;
      --surface: #111116;
      --surface2: #18181f;
      --border: #2a2a38;
      --border-bright: #3a3a50;
      --text: #e8e8f0;
      --text-dim: #9090b0;
      --text-muted: #5050708;
      --accent: #3ddc84;
      --accent-dim: rgba(61, 220, 132, 0.12);
      --accent-glow: rgba(61, 220, 132, 0.35);
      --accent-bright: #56e898;
      --accent-dark: #1a7a40;
      --green-mid: #2ab56e;
      --red: #ff4466;
      --red-dim: rgba(255, 68, 102, 0.15);
      --yellow: #ffcc44;
      --yellow-dim: rgba(255, 204, 68, 0.15);
    }
    html[data-theme="dark"] body::before {
      background-image:
        linear-gradient(rgba(61,220,132,0.04) 1px, transparent 1px),
        linear-gradient(90deg, rgba(61,220,132,0.04) 1px, transparent 1px);
    }
    html[data-theme="dark"] header {
      background: rgba(10,10,12,0.95);
    }
    html[data-theme="dark"] .sidebar {
      background: rgba(17,17,22,0.95);
    }
    html[data-theme="dark"] .terminal-body {
      background: #0d0d10;
    }
    html[data-theme="dark"] .log-text {
      color: #d0f0e0;
    }
    html[data-theme="dark"] .logo-img {
      filter: brightness(0) invert(1);
    }

    /* Theme toggle button */
    .theme-toggle {
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: 4px;
      padding: 5px 8px;
      cursor: pointer;
      font-size: 14px;
      line-height: 1;
      transition: all 0.15s;
    }
    .theme-toggle:hover {
      border-color: var(--border-bright);
      background: var(--surface2);
    }
  </style>
</head>
