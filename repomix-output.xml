        Sin ejecuciones aún
      </div>
    </div>
  </aside>

  <!-- MAIN -->
  <main class="main">
    <div class="panel">

      <!-- Bot selector -->
      <div class="section-title">Seleccionar Bot</div>
      <div class="bot-selector-grid" id="bot-grid">
        <!-- Bots injected here -->
      </div>

      <!-- Config -->
      <div class="section-title">Configuración</div>
      <div class="config-grid">
        <div class="field-group">
          <div class="field-label">Número de Orders</div>
          <input type="number" class="field-input" id="orders-input" value="10" min="1" max="999" />
        </div>

        <div class="field-group">
          <div class="field-label">Modo Headless</div>
          <div class="toggle-row">
            <span class="toggle-label">Sin ventana del navegador</span>
            <label class="toggle">
              <input type="checkbox" id="headless-toggle" checked />
              <div class="toggle-track"></div>
              <div class="toggle-thumb"></div>
            </label>
          </div>
        </div>

        <div class="field-group">
          <div class="field-label">Delay entre pedidos (seg)</div>
          <input type="number" class="field-input" id="delay-input" placeholder="Opcional" min="0" />
        </div>
      </div>

      <!--
      Extra params (shown for bots that support them) -->
      <div id="extra-params-section" style="display:none;">
       <div class="section-title" style="margin-bottom: 12px;">Parámetros Adicionales</div>
        <div class="extra-params-grid" id="extra-params-grid"></div>
      </div>

      <!-- Launch -->
      <button class="launch-btn" id="launch-btn" onclick="launchBot()" disabled>
        ▶ INICIAR BOT
      </button>

      <!-- Selected run terminal -->
      <div id="run-view">
        <div class="empty-state" id="empty-state">
          <div class="empty-state-icon">⚡</div>
          <div class="empty-state-title">SELECCIONA UN BOT</div>
          <div class="empty-state-sub">Y pulsa iniciar para lanzar una ejecución</div>
        </div>

        <!-- Active run view -->
        <div id="active-run-view" style="display:none; flex-direction: column; gap:12px;">
          <div class="section-title">Salida en tiempo real</div>
          <div class="run-info-bar" id="run-info-bar"></div>
          <div class="terminal">
            <div class="terminal-header">
              <div class="terminal-dots">
                <div class="terminal-dot" style="background:#ff6057"></div>
                <div class="terminal-dot" style="background:#ffbd2e"></div>
                <div class="terminal-dot" style="background:#28c840"></div>
              </div>
              <div class="terminal-title" id="terminal-title">bash — python main.py</div>
              <div class="terminal-actions">
                <button class="term-btn" onclick="clearTerminal()">LIMPIAR</button>
                <button class="term-btn" onclick="scrollTerminal()">↓ BAJAR</button>
                <button class="term-btn stop" id="stop-btn" onclick="stopCurrentRun()" style="display:none;">■ DETENER</button>
              </div>
            </div>
            <div class="terminal-body" id="terminal-body">
              <div class="terminal-empty">
                <div class="terminal-empty-icon">⬛</div>
                <span>Esperando salida...</span>
              </div>
            </div>
          </div>
        </div>
      </div>

    </div>
  </main>
</div>

<!-- Toast container -->
<div class="toast-container" id="toast-container"></div>

<script>
const API = '';
let bots = {};
let selectedBot = null;
let currentRunId = null;
let pollInterval = null;
let logOffset = 0;
const ansiUp = new AnsiUp();

const BOT_COLORS = {
  shopify: '#96bf48',
  prestashop8: '#df0067',
  prestashop17: '#e97c0d',
  woocommerce: '#7f54b3'
};

const EXTRA_PARAMS = {
  shopify: [
    { key: 'products-per-order', label: 'Productos por pedido', placeholder: 'Ej: 3' },
    { key: 'slow-mo', label: 'Slow Motion (ms)', placeholder: 'Ej: 500' }
  ],
  woocommerce: [
    { key: 'slow-mo', label: 'Slow Motion (ms)', placeholder: 'Ej: 500' }
  ]
};

// ---- Init ----
async function init() {
  await loadBots();
  await loadRuns();
  setInterval(loadRuns, 3000);
  setInterval(updateActiveCount, 2000);
}

async function loadBots() {
  try {
    const res = await fetch(`${API}/api/bots`);
    const data = await res.json();
    bots = {};
    data.forEach(b => bots[b.id] = b);
    renderBotGrid(data);
  } catch(e) {
    showToast('Error conectando con el servidor', 'error');
    document.getElementById('server-status').innerHTML = '<span style="color:var(--red)">● DESCONECTADO</span>';
  }
}

function renderBotGrid(botList) {
  const grid = document.getElementById('bot-grid');
  grid.innerHTML = botList.map(bot => `
    <div class="bot-select-card ${bot.available ? '' : 'unavailable'}"
         id="card-${bot.id}"
         style="--card-color: ${bot.color}"
         onclick="${bot.available ? `selectBot('${bot.id}')` : ''}">
      <div class="bot-select-check" id="check-${bot.id}">✓</div>
      <div class="bot-select-icon">${bot.icon}</div>
      <div class="bot-select-name">${bot.name}</div>
      ${!bot.available ? '<div style="font-size:10px;color:var(--text-muted);margin-top:4px;font-family:var(--mono)">NO ENCONTRADO</div>' : ''}
    </div>
  `).join('');
}

function selectBot(botId) {
  selectedBot = botId;
  // Update card styles
  Object.keys(bots).forEach(id => {
    const card = document.getElementById(`card-${id}`);
    if (card) card.classList.toggle('selected', id === botId);
  });

  // Extra params
  const extra = EXTRA_PARAMS[botId] || [];
  const section = document.getElementById('extra-params-section');
  const grid = document.getElementById('extra-params-grid');
  if (extra.length > 0) {
    section.style.display = 'block';
    grid.innerHTML = extra.map(p => `
      <div class="field-group">
        <div class="field-label">${p.label}</div>
        <input type="text" class="field-input" id="extra-${p.key}" placeholder="${p.placeholder}" />
      </div>
    `).join('');
  } else {
    section.style.display = 'none';
    grid.innerHTML = '';
  }

  document.getElementById('launch-btn').disabled = false;
  document.getElementById('launch-btn').style.background = bots[botId]?.color || 'var(--accent)';
  document.getElementById('launch-btn').style.color = '#fff';
}

async function launchBot() {
  if (!selectedBot) return;

  const orders = parseInt(document.getElementById('orders-input').value) || 10;
  const headless = document.getElementById('headless-toggle').checked;
  const delay = document.getElementById('delay-input').value;

  // Collect extra params
  const extra = EXTRA_PARAMS[selectedBot] || [];
  const extraParams = {};
  extra.forEach(p => {
    const val = document.getElementById(`extra-${p.key}`)?.value;
    if (val) extraParams[p.key] = val;
  });
  if (delay) extraParams['delay'] = delay;

  const btn = document.getElementById('launch-btn');
  btn.disabled = true;
  btn.textContent = '⟳ INICIANDO...';

  try {
    const res = await fetch(`${API}/api/run`, {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ bot_id: selectedBot, orders, headless, extra_params: extraParams })
    });

    const data = await res.json();
    if (data.run_id) {
      showToast(`Bot iniciado — ID: ${data.run_id}`, 'success');
      await loadRuns();
      viewRun(data.run_id);
    } else {
      showToast(`Error: ${data.error}`, 'error');
    }
  } catch(e) {
    showToast('Error al iniciar el bot', 'error');
  } finally {
    btn.disabled = false;
    btn.innerHTML = '▶ INICIAR BOT';
  }
}

// ---- Runs ----
async function loadRuns() {
  try {
    const res = await fetch(`${API}/api/runs`);
    const data = await res.json();
    renderRunsList(data.reverse());
    updateActiveCount(data);
  } catch(e) {}
}

function renderRunsList(runList) {
  const el = document.getElementById('runs-list');
  if (runList.length === 0) {
    el.innerHTML = '<div style="font-family:var(--mono);font-size:11px;color:var(--text-muted);padding:8px 4px;">Sin ejecuciones aún</div>';
    return;
  }
  el.innerHTML = runList.map(r => `
    <div class="run-item ${r.id === currentRunId ? 'active' : ''}" onclick="viewRun('${r.id}')">
      <div class="run-status-dot dot-${r.status}"></div>
      <div class="run-item-info">
        <div class="run-item-name">${r.bot_icon} ${r.bot_name}</div>
        <div class="run-item-meta">${r.orders} pedidos · ${formatTime(r.started_at)}</div>
      </div>
    </div>
  `).join('');
}

function updateActiveCount(runList) {
  fetch(`${API}/api/runs`).then(r => r.json()).then(data => {
    const active = data.filter(r => r.status === 'running').length;
    document.getElementById('active-count').textContent = `${active} ACTIVOS`;
  }).catch(() => {});
}

async function viewRun(runId) {
  currentRunId = runId;
  logOffset = 0;

  // Clear existing poll
  if (pollInterval) clearInterval(pollInterval);

  document.getElementById('empty-state').style.display = 'none';
  document.getElementById('active-run-view').style.display = 'flex';

  const res = await fetch(`${API}/api/runs/${runId}`);
  const run = await res.json();

  // Update info bar
  updateRunInfoBar(run);

  // Update terminal title
  document.getElementById('terminal-title').textContent = run.command;

  // Show/hide stop button
  document.getElementById('stop-btn').style.display = run.status === 'running' ? 'block' : 'none';

  // Clear and load all logs
  document.getElementById('terminal-body').innerHTML = '';
  const logRes = await fetch(`${API}/api/runs/${runId}/logs`);
  const logData = await logRes.json();
  renderLogs(logData.logs);
  //Linea para controlar los logs
  logOffset = logData.logs ? logData.logs.length : 0;
  scrollTerminal();

  // Poll if running
  if (run.status === 'running') {
    pollInterval = setInterval(() => pollLogs(runId), 800);
  }

  // Refresh run list
  loadRuns();
}

async function pollLogs(runId) {
  try {
    const res = await fetch(`${API}/api/runs/${runId}/logs?offset=${logOffset}`);
    const data = await res.json();
    if (data.logs.length > 0) {
      renderLogs(data.logs);
      logOffset += data.logs.length;
      scrollTerminal();
    }
    if (data.status !== 'running') {
      clearInterval(pollInterval);
      const run = await (await fetch(`${API}/api/runs/${runId}`)).json();
      updateRunInfoBar(run);
      document.getElementById('stop-btn').style.display = 'none';
      loadRuns();
    }
  } catch(e) {}
}

function renderLogs(logs) {
  const body = document.getElementById('terminal-body');
  // Remove empty state
  const empty = body.querySelector('.terminal-empty');
  if (empty) empty.remove();

  logs.forEach(log => {
    const div = document.createElement('div');
    div.className = 'log-line';

    // Detect ANSI-type patterns
    let type = 'stdout';
    const t = log.text.toLowerCase();
    if (log.type === 'system') type = 'system';
    else if (log.type === 'error' || t.includes('error') || t.includes('traceback') || t.includes('exception')) type = 'error';
    else if (t.includes('warn') || t.includes('warning')) type = 'warn';

    div.innerHTML = `
      <span class="log-time">${log.time}</span>
      <span class="log-text ${type}">${ansiUp.ansi_to_html(log.text)}</span>
    `;
    body.appendChild(div);
  });
}

function updateRunInfoBar(run) {
  const bar = document.getElementById('run-info-bar');
  const elapsed = run.ended_at
    ? calcElapsed(run.started_at, run.ended_at)
    : calcElapsed(run.started_at, new Date().toISOString());
  bar.innerHTML = `
    <div class="run-info-field"><span class="run-info-key">ID</span><span class="run-info-val">${run.id}</span></div>
    <div class="run-info-field"><span class="run-info-key">BOT</span><span class="run-info-val">${run.bot_icon} ${run.bot_name}</span></div>
    <div class="run-info-field"><span class="run-info-key">ORDERS</span><span class="run-info-val">${run.orders}</span></div>
    <div class="run-info-field"><span class="run-info-key">HEADLESS</span><span class="run-info-val">${run.headless ? 'SÍ' : 'NO'}</span></div>
    <div class="run-info-field"><span class="run-info-key">TIEMPO</span><span class="run-info-val">${elapsed}</span></div>
    <div class="run-info-field"><span class="status-badge status-${run.status}">${run.status.toUpperCase()}</span></div>
  `;
}

async function stopCurrentRun() {
  if (!currentRunId) return;
  await fetch(`${API}/api/run/${currentRunId}/stop`, { method: 'POST' });
  showToast('Bot detenido', 'info');
  clearInterval(pollInterval);
  document.getElementById('stop-btn').style.display = 'none';
  loadRuns();
}

function clearTerminal() {
  document.getElementById('terminal-body').innerHTML = '';
}

function scrollTerminal() {
  const body = document.getElementById('terminal-body');
  body.scrollTop = body.scrollHeight;
}

// ---- Helpers ----
function formatTime(iso) {
  if (!iso) return '';
  const d = new Date(iso);
  return d.toLocaleTimeString('es', { hour: '2-digit', minute: '2-digit' });
}

function calcElapsed(start, end) {
  const ms = new Date(end) - new Date(start);
  const s = Math.floor(ms / 1000);
  if (s < 60) return `${s}s`;
  return `${Math.floor(s/60)}m ${s%60}s`;
}

function escapeHtml(t) {
  return t.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;');
}

function showToast(msg, type = 'info') {
  const c = document.getElementById('toast-container');
  const el = document.createElement('div');
  el.className = `toast toast-${type}`;
  el.textContent = msg;
  c.appendChild(el);
  setTimeout(() => el.remove(), 3500);
}


function toggleTheme() {
  const html = document.documentElement;
  const btn = document.getElementById('theme-toggle');
  if (html.getAttribute('data-theme') === 'dark') {
    html.removeAttribute('data-theme');
    btn.textContent = '☀️';
    localStorage.setItem('theme', 'light');
  } else {
    html.setAttribute('data-theme', 'dark');
    btn.textContent = '🌙';
    localStorage.setItem('theme', 'dark');
  }
}

// Apply saved theme on load
(function() {
  const saved = localStorage.getItem('theme');
  if (saved === 'dark') {
    document.documentElement.setAttribute('data-theme', 'dark');
    document.addEventListener('DOMContentLoaded', () => {
      const btn = document.getElementById('theme-toggle');
      if (btn) btn.textContent = '🌙';
    });
  }
})();

init();
</script>
</body>
</html>
